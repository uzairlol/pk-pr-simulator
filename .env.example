# Copy to .env and fill in values. Never commit .env.

# PostgreSQL (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+psycopg2://pkpr:devpassword@localhost:5432/pk_pr_simulator

# Weights & Biases
WANDB_PROJECT=pk-pr-simulator
WANDB_ENTITY=
# WANDB_API_KEY=your-key-here

# YouTube Data API (Phase 3+)
# YOUTUBE_API_KEY=

# Reddit API (Phase 3+)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=pk-pr-simulator/0.1.0 (by u/your_reddit_user)

# Simulation defaults
PKPR_RANDOM_SEED=42
PKPR_DATA_DIR=./data
